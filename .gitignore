# Build folder.
/build/

# Test output folder.
/tests/data/

# Media folders.
/media
/media_internal

# Packman folders.
/external/packman/
/tools/.packman/

# External asset dependencies (large, managed out-of-band).
# Treat like a packman dep: keep a placeholder README in tree,
# but never commit the actual scene payload.
/external/assets/*
!/external/assets/README.md

# IDE folders.
/.vs/
/.vscode/

# User files.
/CMakeUserPresets.json

# File types.
*.user
*.suo
*.pyc
*.VC.db
*.VC.opendb
*.pyc
*slang-dump-*
*.mp4
*.tlog
*.bak
*.swp
